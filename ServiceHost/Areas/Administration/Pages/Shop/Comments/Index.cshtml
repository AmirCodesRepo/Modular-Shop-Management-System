@page
@model ServiceHost.Areas.Administration.Pages.Shop.Comments.IndexModel
@{
    Layout = "Shared/_AdminLayout";
    ViewData["title"] = "مدیریت نظرات";
}
<div class="row">
    <div class="col-sm-12">
        <h4 class="page-title pull-right">@ViewData["title"]</h4>
    </div>
</div>
<div class="row">
    <div class="col-md-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title">جستجو در نظرات</h3>
            </div>
            <div class="panel-body">
                <form class="form-inline" role="form" method="get">
                    <div class="form-group">
                        <label class="sr-only" asp-for="SearchModel.Name"></label>
                        <input class="form-control" asp-for="SearchModel.Name" placeholder="نام">
                    </div>
                    <div class="form-group">
                        <label class="sr-only" asp-for="SearchModel.Email"></label>
                        <input class="form-control" asp-for="SearchModel.Email" placeholder="ایمیل">
                    </div>
                    <button type="submit" class="btn btn-success waves-effect waves-light m-l-10">جستجو</button>
                    <a class="btn btn-primary waves-effect waves-light m-l-10" asp-page="./Index">مشاهده همه</a>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row" id="ProductCategoriesDiv">
    <div class="col-md-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title">لیست نظرات</h3>
            </div>
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-12 col-sm-12 col-xs-12">
                        <table id="datatable" class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>نام</th>
                                    <th>ایمیل</th>
                                    <th>متن نطر</th>
                                    <th>تاریخ ثبت نظر</th>
                                    <th>محصول</th>
                                    <th>وضعیت تایید</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Comments)
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>@item.Name</td>
                                        <td>@item.Email</td>
                                        <td>@item.Message</td>
                                        <td>@item.CreationDate</td>
                                        <td>@item.ProductName</td>
                                        <td class="text-center">
                                            @{
                                                @if (!item.IsCanceld && !item.IsConfirmed)
                                                {
                                                    // <i class="fa fa-exclamation-circle fa-3x text-warning"></i>
                                                    <span class="text-warning"> در انتظار تایید</span>
                                                }
                                                @if (item.IsCanceld && !item.IsConfirmed)
                                                {
                                                    // <i class="fa fa-remove fa-3x text-danger"></i>
                                                    <span class="text-danger"> رد شده</span>
                                                }
                                                @if (!item.IsCanceld && item.IsConfirmed)
                                                {
                                                    // <i class="fa fa-check fa-3x text-success"></i>
                                                    <span class="text-success"> تایید شده</span>
                                                }
                                            }
                                        </td>
                                        <td>@item.CreationDate</td>
                                        <td>
                                            @{
                                                if (!item.IsCanceld && !item.IsConfirmed)
                                                {
                                                    <a class="btn btn-danger pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Cancel", new { id = item.Id })">
                                                        رد نظر
                                                    </a>
                                                    <a class="btn btn-success pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Confirm", new { id = item.Id })">
                                                        تایید نظر
                                                    </a>
                                                }
                                                if (item.IsCanceld && !item.IsConfirmed)
                                                {
                                                    <a class="btn btn-success pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Confirm", new { id = item.Id })">
                                                        تایید نظر
                                                    </a>
                                                }
                                                if (!item.IsCanceld && item.IsConfirmed)
                                                {
                                                    <a class="btn btn-danger pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Cancel", new { id = item.Id })">
                                                        رد نظر
                                                    </a>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Script {

    <script src="~/adminTheme/assets/datatables/jquery.dataTables.min.js"></script>
    <script src="~/adminTheme/assets/datatables/dataTables.bootstrap.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#datatable').dataTable();
        });
    </script>
}
