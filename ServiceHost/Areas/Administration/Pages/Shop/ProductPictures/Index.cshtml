@page "{id:int}"
@model ServiceHost.Areas.Administration.Pages.Shop.ProductPictures.IndexModel
@{
    Layout = "Shared/_AdminLayout";
    ViewData["title"] = "مدیریت عکس های محصول";
}

<div class="row">
    <div class="col-sm-12">
        <h4 class="page-title pull-right">@ViewData["title"]</h4>
        <p class="pull-left">
            <a class="btn btn-success btn-lg"
               href="#showmodal=@Url.Page("./index", "Create", new { id = Model.ProductId })">افزودن عکس به محصول</a>
        </p>
    </div>
</div>

<div class="row" id="ProductCategoriesDiv">
    <div class="col-md-12">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title">لیست عکس های محصول</h3>
            </div>
            <div class="panel-body">
                <div class="row">
                    <div class="col-md-12 col-sm-12 col-xs-12">
                        <table id="datatable" class="table table-striped table-bordered">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>عکس</th>
                                    <th>Alt</th>
                                    <th>عنوان</th>
                                    <th>محصول</th>
                                    <th>وضعیت نمایش</th>
                                    <th>تاریخ ایجاد</th>
                                    <th>عملیات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ProductPictures)
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>
                                            <img src="~/ProductPicture/@item.Picture" style="width: 70px; height: 70px" />
                                        </td>
                                        <td>@item.PictureAlt</td>
                                        <td>@item.PictureTitle</td>
                                        <td>@item.Product</td>
                                        <td class="text-center">
                                            @{
                                                @if (item.IsRemoved)
                                                {
                                                    <i class="fa fa-remove fa-3x text-danger"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa fa-check fa-3x text-success"></i>
                                                }
                                            }
                                        </td>
                                        <td>@item.CreationDate</td>
                                        <td>
                                            <a class="btn btn-warning pull-right m-rl-5"
                                               href="#showmodal=@Url.Page("./index", "Edit", new { id = item.Id ,productId =Model.ProductId })">
                                                <i class="fa fa-edit"></i> ویرایش
                                            </a>
                                            @{
                                                @if (!item.IsRemoved)
                                                {
                                                    <a class="btn btn-danger pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Remove", new { id = item.Id , p = Model.ProductId })">
                                                        حذف
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a class="btn btn-success pull-right m-rl-5"
                                                       href="@Url.Page("./index", "Restore", new { id = item.Id, p = Model.ProductId })">
                                                        نمایش
                                                    </a>
                                                }

                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Script {

    <script src="~/adminTheme/assets/datatables/jquery.dataTables.min.js"></script>
    <script src="~/adminTheme/assets/datatables/dataTables.bootstrap.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('#datatable').dataTable();
        });
    </script>
}
