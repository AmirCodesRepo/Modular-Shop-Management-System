@model AccountManagement.Application.Contracts.AccountAgg.ChangePassword
@{
}

<div class="modal-header">
    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
    <h4 class="modal-title">ایجاد محصول جدید</h4>
</div>

<form asp-page="./index" asp-page-handler="ChangePassword"
      method="post"
      data-ajax="true"
      data-callback=""
      data-action="Refresh"
      enctype="multipart/form-data">
    <div class="modal-body">
        <div class="row">

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label asp-for="Password" class="control-label">رمز عبور</label>
                        <input type="text" class="form-control" asp-for="Password" onchange="makeSlug('Name', 'Slug')">
                        <span asp-validation-for="Password" class="error"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label asp-for="RePassword" class="control-label">تکرار رمز عبور</label>
                        <input type="text" class="form-control" asp-for="RePassword" onchange="makeSlug('Name', 'Slug')">
                        <span asp-validation-for="RePassword" class="error"></span>
                    </div>
                </div>
            </div>
            <input type="hidden" asp-for="Id" value="@Model.Id" />
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-default waves-effect" data-dismiss="modal">بستن</button>
        <button type="submit" class="btn btn-info waves-effect waves-light">ایجاد</button>
    </div>
</form>