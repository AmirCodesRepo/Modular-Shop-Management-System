@page
@model ServiceHost.Pages.AccountModel
@{
}
<div class="breadcrumb-area section-space--half">
    <div class="container wide">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb-wrapper breadcrumb-bg">
                    <div class="breadcrumb-content">
                        <h2 class="breadcrumb-content__title">ورود و ثبت نام</h2>
                        <ul class="breadcrumb-content__page-map">
                            <li><a asp-page="/Index">خانه</a></li>
                            <li class="active">ورود - ثبت نام</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-content-area">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="page-wrapper">
                    <div class="page-content-wrapper">
                        <div class="row">
                            <div class="col-sm-12 col-md-12 col-xs-12 col-lg-6">
                                @if (@Model.LoginMessage != null)
                                {
                                    <div class="alert alert-danger">
                                        @Model.LoginMessage
                                    </div>
                                }
                                <form method="post" asp-page-handler="Login">
                                    <div class="login-form">
                                        <h4 class="login-title">ورود</h4>
                                        <div class="row">
                                            <div class="col-md-12 col-12">
                                                <label>نام کاربری</label>
                                                <input type="text" asp-for="login.UserName" placeholder="نام کاربری خود را وارد کنید">
                                                <span asp-validation-for="login.UserName"></span>
                                            </div>
                                            <div class="col-12">
                                                <label>کلمه عبور</label>
                                                <input type="password" asp-for="login.Password" placeholder="کلمه عبور خود را وارد کنید">
                                                <span asp-validation-for="login.Password"></span>
                                            </div>
                                            <div class="col-sm-6 text-left text-sm-right">
                                                <a href="#" class="forget-pass-link"> کلمه عبور خود را فراموش کرده اید؟</a>
                                            </div>

                                            <div class="col-md-12">
                                                <button type="submit" class="register-button">ورود</button>
                                            </div>

                                        </div>
                                    </div>

                                </form>
                            </div>
                            <div class="col-sm-12 col-md-12 col-lg-6 col-xs-12">
                                <form method="post" asp-page-handler="Signin">
                                    @if (@Model.SigninMessage != null)
                                    {
                                        <div class="alert alert-danger">
                                            @Model.SigninMessage
                                        </div>
                                    }
                                    <div class="login-form">
                                        <h4 class="login-title">ثبت نام</h4>

                                        <div class="row">
                                            <div class="col-md-6 col-12 mb-20">
                                                <label>نام کامل</label>
                                                <input type="text" asp-for="register.FullName" placeholder="نام کامل خود را وارد کنید.">
                                                <span asp-validation-for="register.FullName"></span>
                                            </div>
                                            <div class="col-md-6 col-12 mb-20">
                                                <label>نام کاربری</label>
                                                <input type="text" asp-for="register.UserName" placeholder="نام کاربری خود را وارد کنید">
                                                <span asp-validation-for="register.UserName"></span>
                                            </div>
                                            <div class="col-md-12 mb-20">
                                                <label>موبایل</label>
                                                <input type="number" asp-for="register.Mobile" placeholder="شماره موبایل خود را وارد کنید">
                                                <span asp-validation-for="register.Mobile"></span>
                                            </div>
                                            <div class="col-md-12 mb-20">
                                                <label>کلمه عبور</label>
                                                <input type="password" asp-for="register.Password" placeholder="کلمه عبور خود را وارد کنید">
                                                <span asp-validation-for="register.Password"></span>
                                            </div>
                                            <div class="col-md-12 mb-20">
                                                <label>تکرار کلمه عبور</label>
                                                <input type="password" asp-for="register.RePassword" placeholder="تکرار کلمه عبور خود را وارد کنید">
                                                <span asp-validation-for="register.RePassword"></span>
                                            </div>
                                            <div class="col-12">
                                                <button class="register-button mt-0">ثبت نام</button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>